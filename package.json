{
  "name": "chromatography",
  "version": "8.0.1",
  "description": "Tools for storing, searching and analyzing GC/MS data",
  "main": "lib/index.js",
  "module": "src/index.js",
  "types": "chromatography.d.ts",
  "sideEffects": false,
  "cheminfo": {
    "build": {
      "namedExports": {
        "utf8": [
          "decode",
          "encode"
        ]
      }
    }
  },
  "files": [
    "chromatography.d.ts",
    "lib",
    "src"
  ],
  "scripts": {
    "build": "cheminfo-build --entry src/index.js --root Chromatography",
    "eslint": "eslint src --cache",
    "eslint-fix": "npm run eslint -- --fix",
    "prepack": "rollup -c",
    "prettier": "prettier --check src",
    "prettier-write": "prettier --write src",
    "test": "npm run test-only && npm run eslint && npm run prettier",
    "test-only": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cheminfo/chromatography.git"
  },
  "author": "Michaël Zasso",
  "contributors": [
    "Miguel Asencio <maasencioh@gmail.com>"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/cheminfo/chromatography/issues"
  },
  "homepage": "https://github.com/cheminfo/chromatography#readme",
  "devDependencies": {
    "@babel/plugin-transform-modules-commonjs": "^7.28.6",
    "@vitest/coverage-v8": "^4.1.5",
    "cheminfo-build": "^1.3.2",
    "convert-to-jcamp": "^7.0.0",
    "eslint": "^9.39.4",
    "eslint-config-cheminfo": "^18.0.0",
    "jest-matcher-deep-close-to": "^3.0.2",
    "prettier": "^3.8.3",
    "rollup": "^4.60.2",
    "spectrum-generator": "^8.2.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "binary-search": "^1.3.6",
    "is-any-array": "^3.0.0",
    "isotopic-distribution": "^3.7.0",
    "jcampconverter": "^12.3.0",
    "mf-generator": "^3.3.22",
    "mf-parser": "^3.9.0",
    "ml-airpls": "^2.2.0",
    "ml-array-max": "^2.0.0",
    "ml-array-mean": "^2.0.0",
    "ml-array-median": "^2.0.0",
    "ml-array-sum": "^2.0.0",
    "ml-gsd": "^13.1.1",
    "ml-matrix": "^6.12.2",
    "ml-ngmca": "^1.0.0",
    "ml-pca": "^4.1.1",
    "ml-regression-polynomial": "^4.0.0",
    "ml-spectra-processing": "^14.28.1",
    "mzdata": "^4.0.0",
    "netcdf-gcms": "^4.0.0",
    "xy-parser": "^6.0.1"
  }
}
